{
  "name": "lados",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm build:packs && pnpm --parallel --filter web --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm build:packs && pnpm --filter api dev",
    "build": "pnpm -r build",
    "build:packages": "pnpm --filter \"./packages/**\" build",
    "build:packs": "pnpm --filter \"./packs/**\" build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "validate:official-packs": "pnpm --filter @lados/pack-sdk build && node tools/validate-official-packs.cjs",
    "baseline:phase27": "node tools/generate-phase27-runtime-baseline.cjs",
    "readiness:check": "node tools/generate-phase27-runtime-baseline.cjs --check",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
