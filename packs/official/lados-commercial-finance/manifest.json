{
  "contractVersion": "lados.capability-pack.v1",
  "id": "lados.commercial-finance",
  "version": "0.2.0",
  "displayName": "Commercial Finance",
  "layer": "L1",
  "status": "draft",
  "runtimeStatus": "runtime_enabled",
  "description": "Official Lados commercial finance capability pack for invoices, payments, purchase orders, approval records, and retention.",
  "ownerBoundary": [
    "invoice submission",
    "invoice verification",
    "invoice approval record",
    "payment record",
    "purchase order creation",
    "purchase order approval record",
    "retention claim and release record"
  ],
  "mustNotOwn": [
    "RFQ or quotation comparison",
    "BOQ measurement",
    "progress claim assessment",
    "payment gateway execution without controlled integration"
  ],
  "dependencies": [
    "lados.workflow-foundation",
    "lados.resource-operations",
    "lados.human-work",
    "lados.document-intelligence"
  ],
  "capabilities": [
    "finance.invoice.submit",
    "finance.invoice.verify",
    "finance.invoice.approval_record",
    "finance.payment.record",
    "finance.po.create",
    "finance.po.approval_record",
    "finance.retention.claim_release",
    "finance.retention.record_release"
  ],
  "nodes": [
    "lados.finance.submit_invoice",
    "lados.finance.verify_invoice",
    "lados.finance.record_invoice_approval",
    "lados.finance.record_payment",
    "lados.finance.create_purchase_order",
    "lados.finance.record_purchase_order_approval",
    "lados.finance.claim_retention_release",
    "lados.finance.record_retention_release"
  ],
  "knowledgePacks": {
    "required": [],
    "recommended": [
      "invoice validation rules",
      "payment terms SOP",
      "retention rules",
      "finance approval matrix"
    ]
  },
  "guardrails": [
    "Approval nodes must record human approval; they must not autonomously approve commercial obligations.",
    "Payment nodes record payment unless a controlled integration pack explicitly executes payment.",
    "Finance outputs must preserve source references, assumptions, and review status."
  ],
  "prototypeReferences": [
    "finance-pack",
    "contractor-pack"
  ],
  "verification": {
    "manifest": "verified — S5 fix: nodes.json only defined 5 of the 8 nodes manifest.json declared (record_purchase_order_approval, claim_retention_release, record_retention_release were missing); added all 3",
    "runtime": "implemented — all 8 nodes implemented. No new resource types needed: reuses finance_invoice/purchase_order/retention_release from migration 0043",
    "canvas": "not_started",
    "templates": "not_started"
  },
  "visual": {
    "category": "Commercial Finance",
    "icon": "ReceiptText",
    "color": "#dc2626",
    "paletteGroup": "Business Operations"
  },
  "resourceViews": [
    {
      "type": "invoice",
      "displayName": "Invoice",
      "displayNamePlural": "Invoices",
      "icon": "🧾",
      "views": {
        "list": {
          "primaryField": "name",
          "secondaryField": "data.total",
          "badgeField": "state",
          "mobileLayout": "card"
        },
        "inlineActions": [
          { "label": "Submit for Approval", "node": "state.change", "visibleInStates": ["draft"], "icon": "📤" },
          { "label": "Record Payment", "node": "lados.finance.record_payment", "visibleInStates": ["approved"], "icon": "💳", "requiresConfirm": true }
        ]
      }
    },
    {
      "type": "payment",
      "displayName": "Payment",
      "displayNamePlural": "Payments",
      "icon": "💳",
      "views": {
        "list": {
          "primaryField": "name",
          "secondaryField": "data.amount",
          "badgeField": "state",
          "mobileLayout": "card"
        },
        "inlineActions": [
          { "label": "Reconcile", "node": "state.change", "visibleInStates": ["recorded"], "icon": "✅", "requiresConfirm": true }
        ]
      }
    }
  ]
}
