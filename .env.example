# ─────────────────────────────────────────────
# QS-WFUI Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# ── Supabase (Frontend — public values, safe to expose) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase (Backend — keep secret) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Storage ──
STORAGE_BUCKET=qsos-documents

# ── Queue (Sprint 4 — not needed yet) ──
REDIS_URL=redis://localhost:6379

# ── AI Provider (Sprint 6 — not needed yet) ──
AI_PROVIDER_API_KEY=your-openai-compatible-key
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_MODEL=gpt-4o

# ── App URLs ──
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
APP_URL=http://localhost:3000

# ── API Server ──
PORT=4000
NODE_ENV=development
